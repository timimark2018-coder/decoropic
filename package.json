{
  "name": "decoropic-decolovely",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "package:deploy": "npm run build && /bin/zsh ./scripts/package-deploy.sh",
    "package:theme": "/bin/zsh ./scripts/package-theme.sh",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "next typegen && tsc --project tsconfig.typecheck.json --noEmit --incremental false",
    "verify": "npm run lint && npm run test && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.103.0",
    "clsx": "2.1.1",
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.3",
    "postcss": "8.5.9",
    "tailwindcss": "^3.4.17",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  }
}
