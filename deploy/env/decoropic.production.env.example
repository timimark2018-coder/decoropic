# Decoropic production environment
# Copy this file to the server as `.env.production` or source it in your process manager.

NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1

NEXT_PUBLIC_SITE_URL=https://www.decoropic.com
NEXT_PUBLIC_PRODUCT_CENTER_URL=https://www.decolovely.com

NEXT_PUBLIC_CONTACT_WHATSAPP=
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=Available on request
NEXT_PUBLIC_CONTACT_EMAIL=hello@decoropic.com
NEXT_PUBLIC_CONTACT_LOCATION=Ghana

GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# Lead capture fallback
# Current app stores submissions locally under `.submissions/`
# Keep this false unless you intentionally want file uploads on the server.
ALLOW_LOCAL_UPLOADS_IN_PRODUCTION=false

# Optional future backend integration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
SUPABASE_STORAGE_PUBLIC=true
